# Base RPC (public endpoint works for reads, use Alchemy/Infura for writes)
BASE_RPC_URL=https://mainnet.base.org

# Agent wallet private key (0x-prefixed)
PRIVATE_KEY=0x...

# ── Mainnet contract addresses (from forge script output) ──
VAULT_ADDRESS=0x...
FACTORY_ADDRESS=0x...
REGISTRY_ADDRESS=0x...

# ── Testnet contract addresses (Base Sepolia — used with --testnet flag) ──
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VAULT_ADDRESS_TESTNET=0x...
FACTORY_ADDRESS_TESTNET=0x997FAcbAB167Afa2e70828Dc8bff5647773eA31D
REGISTRY_ADDRESS_TESTNET=0xfb5d298e13D79aa5960F4c6233348b86b3B23e99

# Durin L2 Registrar (ENS subnames — sherwoodagent.eth)
L2_REGISTRAR_ADDRESS=0x1fCbe9dFC25e3fa3F7C55b26c7992684A4758b47

# Venice AI (strategy research / chat intelligence)
VENICE_API_KEY=

# Pinata (IPFS metadata for syndicate descriptions)
PINATA_API_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud

# The Graph subgraph (for syndicate discovery — optional, falls back to on-chain)
SUBGRAPH_URL=

# XMTP (chat) — uses PRIVATE_KEY for identity, no extra config needed
# Optional: bot wallet for dashboard read access (--public-chat)
DASHBOARD_SPECTATOR_ADDRESS=
