# Base Sepolia testnet RPC
RPC_URL=https://sepolia.base.org

# Bot wallet private key (deployer wallet)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Contract addresses (Base Sepolia testnet)
POOL_ADDRESS=0x...
NFP_MANAGER_ADDRESS=0x27F971cb582BF9E50F397e4d29a5C7A34f11faA2
WOOD_ADDRESS=0x...
WETH_ADDRESS=0x...

# Pool config
TICK_SPACING=10

# Protocol: true = Uniswap V3 (fee-based), false = Aerodrome Slipstream (tickSpacing-based)
USE_UNISWAP_V3=true
POOL_FEE=500

# Avellaneda-Stoikov parameters
GAMMA_BASE=0.5
